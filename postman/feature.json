            "body": {
              "mode": "raw",
              "raw": "{\n  \"annotation\": \"Test event annotation for comments testing\",\n  \"category\": {{categoryId}},\n  \"description\": \"Test event description for comments testing purposes\",\n  \"eventDate\": \"2099-12-30 23:59:59\",\n  \"location\": {\n    \"lat\": 55.7558,\n    \"lon\": 37.6176\n  },\n  \"paid\": false,\n  \"participantLimit\": 0,\n  \"requestModeration\": true,\n  \"title\": \"Test Event for Comments\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}",
                "events"
              ]
            }
          }
        },
        {
          "name": "Публикация Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stateAction\": \"PUBLISH_EVENT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/events/{{eventId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "events",
                "{{eventId}}"
              ]
            }
          }
        }
      ]
