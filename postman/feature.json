                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "users"
              ]
            }
          }
        },
        {
          "name": "Добавление события",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('eventId', jsonData.id);"
