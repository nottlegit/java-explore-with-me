{
  "info": {
    "name": "Test Explore With Me - Feature Comments",
    "schema": "https://schema.postman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "categoryId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "userId2",
      "value": ""
    },
    {
      "key": "eventId",
      "value": ""
    },
    {
      "key": "commentId",
      "value": ""
    },
    {
      "key": "commentId2",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Добавление категории",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('categoryId', jsonData.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Category {{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "categories"
              ]
            }
          }
        },
        {
          "name": "Добавление пользователя id 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
